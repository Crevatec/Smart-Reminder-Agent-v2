# Smart Reminder Agent v2 — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# SMTP / Email (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=Smart Reminders <your@gmail.com>

# CORS (set to your domain in production)
ALLOWED_ORIGIN=http://localhost:3000

# ─── HOW TO GET GMAIL APP PASSWORD ───────────────────────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: Google Account → Security → 2-Step Verification → App Passwords
# 3. Select "Mail" and your device, generate a 16-character password
# 4. Paste that password as SMTP_PASS above (no spaces)
#
# ─── HOW TO GET SLACK WEBHOOK URL ─────────────────────────────────────────────
# 1. Go to: https://api.slack.com/apps
# 2. Create New App → From Scratch
# 3. Features → Incoming Webhooks → Activate
# 4. Add New Webhook to Workspace → Select channel
# 5. Copy the webhook URL into the app's Settings → Channels → Slack Webhook URL
